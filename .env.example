# Required: Google Sheets configuration
GOOGLE_SHEET_ID=your-sheet-id-here
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./.tokens/token.json

# Optional: Anthropic API (only if enabling Claude features)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Feature flags
ENABLE_CLAUDE_FALLBACK=False
TC_ANALYZER_MODE=keyword
ENABLE_JS_RENDERING=True
JS_RENDERING_SUSPICION_THRESHOLD=3
JS_RENDERING_TIMEOUT_SECONDS=15

# Performance
HTTP_TIMEOUT_SECONDS=8
DUCKDUCKGO_TIMEOUT_SECONDS=12
TOTAL_DISCOVERY_BUDGET_SECONDS=150
TOTAL_TC_BUDGET_SECONDS=60

# Genie backend database
#   Leave GENIE_DB_URL unset → SQLite at ./genie.db (local dev default).
#   Set it to a Postgres DSN in production (Render/Railway/managed PG):
# GENIE_DB_URL=postgresql://user:pass@host:5432/genie
# GENIE_DB_PATH=./genie.db        # SQLite path override (when GENIE_DB_URL unset)
# OPR_API_KEY=                    # OpenPageRank (Keywords Everywhere) for PR metric
# GENIE_CORS_ORIGINS=http://localhost:3000   # comma-separated allowed frontends
EOF